{
  "name": "car-flip-crm",
  "version": "0.0.1",
  "private": true,
  "description": "Car Flip CRM — monorepo (Node/Express backend + React frontend)",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently --names \"server,client\" --prefix-colors \"cyan,magenta\" \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "start": "concurrently --names \"server,client\" --prefix-colors \"cyan,magenta\" \"npm run start --workspace=server\" \"npm run start --workspace=client\"",
    "build": "npm run build --workspace=client",
    "test": "npm run test --workspace=server && npm run test --workspace=client",
    "lint": "npm run lint --workspace=server && npm run lint --workspace=client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
